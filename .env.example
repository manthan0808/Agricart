# Agricart Database Configuration Template
# Copy this file to .env and fill in your actual credentials

DB_HOST=your_supabase_host_here
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your_supabase_password_here
DB_TYPE=pgsql

# Admin Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=secure_password_here
