{
  "functions": {
    "**/*.php": {
      "runtime": "vercel-php@0.7.3",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/login/login.php"
    },
    {
      "src": "/images/(.*)",
      "dest": "/images/$1"
    },
    {
      "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|webp|avif|svg|ico|woff|woff2|ttf|pdf))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}